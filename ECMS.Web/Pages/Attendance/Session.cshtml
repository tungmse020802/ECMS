@page "{id:int}"
@using ECMS.Web.Models
@model ECMS.Web.Pages.Attendance.SessionModel
@{
    ViewData["Title"] = "Take attendance";
}

<section class="content-card mb-4">
    <div class="d-flex justify-content-between align-items-start gap-3">
        <div>
            <div class="eyebrow">Attendance sheet</div>
            <h1 class="mb-1">@Model.Session!.ClassName</h1>
            <p class="text-secondary mb-0">
                @Model.Session.ClassDate.ToString("dd MMM yyyy") |
                @Model.Session.StartTime.ToString(@"hh\:mm") - @Model.Session.EndTime.ToString(@"hh\:mm") |
                Room @Model.Session.RoomName
            </p>
        </div>
        <a asp-page="/Attendance/Index" class="btn btn-outline-secondary">Back</a>
    </div>
</section>

<section class="form-shell">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="table-responsive">
            <table class="table data-table align-middle">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Student</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var index = 0; index < Model.Entries.Count; index++)
                    {
                        <tr>
                            <td>
                                @Model.Entries[index].StudentCode
                                <input type="hidden" asp-for="Entries[index].StudentId" />
                                <input type="hidden" asp-for="Entries[index].StudentCode" />
                                <input type="hidden" asp-for="Entries[index].StudentName" />
                            </td>
                            <td>@Model.Entries[index].StudentName</td>
                            <td>
                                <select asp-for="Entries[index].Status" asp-items="Html.GetEnumSelectList<AttendanceStatus>()" class="form-select"></select>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save attendance</button>
            <a asp-page="/Attendance/Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</section>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
