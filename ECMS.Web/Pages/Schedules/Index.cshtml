@page
@model ECMS.Web.Pages.Schedules.IndexModel
@{
    ViewData["Title"] = "Timetable";

    var bands = new[]
    {
        new { Label = "Morning", Range = "06:00 - 11:59", Start = new TimeSpan(6, 0, 0), End = new TimeSpan(12, 0, 0) },
        new { Label = "Afternoon", Range = "12:00 - 16:59", Start = new TimeSpan(12, 0, 0), End = new TimeSpan(17, 0, 0) },
        new { Label = "Evening", Range = "17:00 - 21:59", Start = new TimeSpan(17, 0, 0), End = new TimeSpan(22, 0, 0) }
    };
}

<section class="table-shell">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <div class="eyebrow">UC03 / UC04</div>
            <h1 class="mb-1">Timetable</h1>
            <p class="text-secondary mb-0">@Model.BoardDescription</p>
        </div>
        @if (Model.CanManageSchedule)
        {
            <a asp-page="/Schedules/Create" class="btn btn-primary">Create session</a>
        }
    </div>

    <form method="get" class="filter-bar mb-4">
        <div>
            <label asp-for="Date" class="form-label">Date</label>
            <input asp-for="Date" class="form-control" type="date" />
        </div>
        <div>
            <label asp-for="ViewMode" class="form-label">View</label>
            <select asp-for="ViewMode" class="form-select">
                <option value="Week">Week</option>
                <option value="Day">Day</option>
            </select>
        </div>
        <div>
            <label asp-for="ClassId" class="form-label">Class</label>
            <select asp-for="ClassId" asp-items="Model.ClassOptions" class="form-select">
                <option value="">All accessible classes</option>
            </select>
        </div>
        <div>
            <button type="submit" class="btn btn-outline-primary">Apply filters</button>
        </div>
    </form>

    <div class="timetable-toolbar mb-4">
        <div class="text-secondary small">Showing sessions for <strong>@Model.RangeLabel</strong>.</div>
        <div class="week-nav">
            <a asp-page="/Schedules/Index"
               asp-route-date="@Model.PreviousRangeText"
               asp-route-viewMode="@Model.ViewMode"
               asp-route-classId="@Model.ClassId"
               class="btn btn-outline-secondary btn-sm">
                Previous
            </a>
            <a asp-page="/Schedules/Index"
               asp-route-date="@DateTime.UtcNow.Date.ToString("yyyy-MM-dd")"
               asp-route-viewMode="@Model.ViewMode"
               asp-route-classId="@Model.ClassId"
               class="btn btn-outline-primary btn-sm">
                Today
            </a>
            <a asp-page="/Schedules/Index"
               asp-route-date="@Model.NextRangeText"
               asp-route-viewMode="@Model.ViewMode"
               asp-route-classId="@Model.ClassId"
               class="btn btn-outline-secondary btn-sm">
                Next
            </a>
        </div>
    </div>

    @if (Model.Sessions.Count == 0)
    {
        <div class="empty-timetable">
            <h2 class="section-title mb-2">No sessions in this range</h2>
            <p class="text-secondary mb-0">Try another week, date, or class filter.</p>
        </div>
    }
    else if (Model.IsWeekView)
    {
        <div class="week-board">
            <div class="week-board-grid">
                <div class="week-board-corner">
                    <div class="eyebrow mb-1">Grid</div>
                    <strong>Study periods</strong>
                    <div class="small text-secondary">Grouped by day and time band</div>
                </div>

                @foreach (var day in Model.VisibleDates)
                {
                    var isToday = day.Date == DateTime.UtcNow.Date;
                    <div class="week-board-day @(isToday ? "today" : string.Empty)">
                        <div class="week-board-day-name">@day.ToString("dddd")</div>
                        <div class="week-board-day-date">@day.ToString("dd MMM")</div>
                    </div>
                }

                @foreach (var band in bands)
                {
                    <div class="week-board-band-label">
                        <span>@band.Label</span>
                        <small>@band.Range</small>
                    </div>

                    @foreach (var day in Model.VisibleDates)
                    {
                        var cellSessions = Model.Sessions
                            .Where(session =>
                                session.ClassDate.Date == day.Date &&
                                session.StartTime < band.End &&
                                session.EndTime > band.Start)
                            .OrderBy(session => session.StartTime)
                            .ToList();

                        <div class="week-board-cell">
                            @if (cellSessions.Count == 0)
                            {
                                <div class="cell-empty">No class</div>
                            }
                            else
                            {
                                @foreach (var session in cellSessions)
                                {
                                    var statusClass = session.Status.ToString().ToLowerInvariant();

                                    <article class="session-chip @statusClass">
                                        <div class="session-chip-top">
                                            <span class="session-chip-time">@session.StartTime.ToString(@"hh\:mm") - @session.EndTime.ToString(@"hh\:mm")</span>
                                            <span class="pill-status @statusClass">@session.Status</span>
                                        </div>
                                        <h2>@session.ClassName</h2>
                                        <div class="session-chip-meta">@session.RoomName</div>
                                        <div class="session-chip-meta">@session.TeacherName</div>

                                        @if (Model.CanManageSchedule)
                                        {
                                            <div class="session-chip-actions">
                                                <a asp-page="/Schedules/Edit" asp-route-id="@session.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
                                                @if (session.Status == ECMS.Web.Models.ScheduleStatus.Scheduled)
                                                {
                                                    <form method="post" asp-page-handler="Cancel" class="d-inline">
                                                        <input type="hidden" name="id" value="@session.Id" />
                                                        <input type="hidden" name="date" value="@Model.Date?.ToString("yyyy-MM-dd")" />
                                                        <input type="hidden" name="viewMode" value="@Model.ViewMode" />
                                                        <input type="hidden" name="classId" value="@Model.ClassId" />
                                                        <button type="submit" class="btn btn-outline-danger btn-sm">Cancel</button>
                                                    </form>
                                                }
                                            </div>
                                        }
                                    </article>
                                }
                            }
                        </div>
                    }
                }
            </div>
        </div>
    }
    else
    {
        <div class="day-band-grid">
            @foreach (var band in bands)
            {
                var bandSessions = Model.Sessions
                    .Where(session => session.StartTime < band.End && session.EndTime > band.Start)
                    .OrderBy(session => session.StartTime)
                    .ToList();

                <section class="day-band-column">
                    <header class="day-band-header">
                        <div class="day-band-name">@band.Label</div>
                        <div class="day-band-range">@band.Range</div>
                    </header>

                    @if (bandSessions.Count == 0)
                    {
                        <div class="cell-empty">No class in this period</div>
                    }
                    else
                    {
                        <div class="day-band-stack">
                            @foreach (var session in bandSessions)
                            {
                                var statusClass = session.Status.ToString().ToLowerInvariant();

                                <article class="session-chip @statusClass">
                                    <div class="session-chip-top">
                                        <span class="session-chip-time">@session.StartTime.ToString(@"hh\:mm") - @session.EndTime.ToString(@"hh\:mm")</span>
                                        <span class="pill-status @statusClass">@session.Status</span>
                                    </div>
                                    <h2>@session.ClassName</h2>
                                    <div class="session-chip-meta">@session.RoomName</div>
                                    <div class="session-chip-meta">@session.TeacherName</div>

                                    @if (Model.CanManageSchedule)
                                    {
                                        <div class="session-chip-actions">
                                            <a asp-page="/Schedules/Edit" asp-route-id="@session.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
                                            @if (session.Status == ECMS.Web.Models.ScheduleStatus.Scheduled)
                                            {
                                                <form method="post" asp-page-handler="Cancel" class="d-inline">
                                                    <input type="hidden" name="id" value="@session.Id" />
                                                    <input type="hidden" name="date" value="@Model.Date?.ToString("yyyy-MM-dd")" />
                                                    <input type="hidden" name="viewMode" value="@Model.ViewMode" />
                                                    <input type="hidden" name="classId" value="@Model.ClassId" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm">Cancel</button>
                                                </form>
                                            }
                                        </div>
                                    }
                                </article>
                            }
                        </div>
                    }
                </section>
            }
        </div>
        <div class="day-agenda mt-4">
            @foreach (var session in Model.Sessions.OrderBy(session => session.StartTime))
            {
                var statusClass = session.Status.ToString().ToLowerInvariant();

                <article class="agenda-row">
                    <div class="agenda-row-time">
                        <div class="agenda-row-date">@session.ClassDate.ToString("dd MMM yyyy")</div>
                        <div>@session.StartTime.ToString(@"hh\:mm") - @session.EndTime.ToString(@"hh\:mm")</div>
                    </div>
                    <div class="agenda-row-body">
                        <h2>@session.ClassName</h2>
                        <div class="session-chip-meta">@session.RoomName</div>
                        <div class="session-chip-meta">@session.TeacherName</div>
                    </div>
                    <div class="agenda-row-actions">
                        <span class="pill-status @statusClass">@session.Status</span>
                        @if (Model.CanManageSchedule)
                        {
                            <div class="session-chip-actions justify-content-end">
                                <a asp-page="/Schedules/Edit" asp-route-id="@session.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
                                @if (session.Status == ECMS.Web.Models.ScheduleStatus.Scheduled)
                                {
                                    <form method="post" asp-page-handler="Cancel" class="d-inline">
                                        <input type="hidden" name="id" value="@session.Id" />
                                        <input type="hidden" name="date" value="@Model.Date?.ToString("yyyy-MM-dd")" />
                                        <input type="hidden" name="viewMode" value="@Model.ViewMode" />
                                        <input type="hidden" name="classId" value="@Model.ClassId" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Cancel</button>
                                    </form>
                                }
                            </div>                            
                        }
                    </div>
                </article>
            }
        </div>
    }
</section>
