@page
@model ECMS.Web.Pages.Students.IndexModel
@{
    ViewData["Title"] = "Students";
}

<section class="table-shell">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="eyebrow">Roster</div>
            <h1 class="mb-1">Student management</h1>
            <p class="text-secondary mb-0">Maintain student profiles, portal-account links, and class enrollments.</p>
        </div>
        <a asp-page="/Students/Create" class="btn btn-primary">Add student</a>
    </div>

    <div class="table-responsive">
        <table class="table data-table align-middle">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Email</th>
                    <th>Portal account</th>
                    <th>Enrolled classes</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Students)
                {
                    <tr>
                        <td>
                            <strong>@item.FullName</strong>
                            <div class="small text-secondary">@item.StudentCode</div>
                        </td>
                        <td>@(item.Email ?? "Not set")</td>
                        <td>@(item.PortalUserName ?? "Unlinked")</td>
                        <td>@item.EnrollmentCount</td>
                        <td class="text-end">
                            <a asp-page="/Students/Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Details</a>
                            <a asp-page="/Students/Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
