@page
@model ECMS.Web.Pages.Scores.EntryModel
@{
    ViewData["Title"] = "Score entry";
}

<section class="table-shell mb-4">
    <div class="mb-4">
        <div class="eyebrow">UC06</div>
        <h1 class="mb-1">Score entry</h1>
        <p class="text-secondary mb-0">Select a class and score type, then enter results on the 0-10 scale.</p>
    </div>

    <form method="get" class="filter-bar">
        <div>
            <label asp-for="ClassId" class="form-label">Class</label>
            <select asp-for="ClassId" asp-items="Model.ClassOptions" class="form-select">
                <option value="">Select a class</option>
            </select>
        </div>
        <div>
            <label asp-for="ScoreTypeId" class="form-label">Score type</label>
            <select asp-for="ScoreTypeId" asp-items="Model.ScoreTypeOptions" class="form-select">
                <option value="">Select a score type</option>
            </select>
        </div>
        <div>
            <button type="submit" class="btn btn-outline-primary">Load students</button>
        </div>
    </form>
</section>

@if (Model.Entries.Count > 0)
{
    <section class="form-shell">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h2 class="section-title mb-1">@Model.SelectedClassName</h2>
                <p class="text-secondary mb-0">Entering <strong>@Model.SelectedScoreTypeName</strong> scores.</p>
            </div>
        </div>

        <form method="post">
            <input type="hidden" asp-for="ClassId" />
            <input type="hidden" asp-for="ScoreTypeId" />
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="table-responsive">
                <table class="table data-table align-middle">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Student</th>
                            <th>Score</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var index = 0; index < Model.Entries.Count; index++)
                        {
                            <tr>
                                <td>
                                    @Model.Entries[index].StudentCode
                                    <input type="hidden" asp-for="Entries[index].StudentId" />
                                    <input type="hidden" asp-for="Entries[index].StudentCode" />
                                    <input type="hidden" asp-for="Entries[index].StudentName" />
                                </td>
                                <td>@Model.Entries[index].StudentName</td>
                                <td>
                                    <input asp-for="Entries[index].Value" class="form-control" type="number" min="0" max="10" step="0.01" />
                                </td>
                                <td>
                                    <input asp-for="Entries[index].Notes" class="form-control" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save scores</button>
                <a asp-page="/Scores/Index" asp-route-classId="@Model.ClassId" class="btn btn-outline-secondary">Open scoreboard</a>
            </div>
        </form>
    </section>
}
