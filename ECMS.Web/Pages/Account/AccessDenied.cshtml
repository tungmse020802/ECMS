@page
@model ECMS.Web.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Access denied";
}

<section class="empty-state">
    <div class="eyebrow">Access denied</div>
    <h1>You do not have permission to open this area.</h1>
    <p class="text-secondary">If you think this is incorrect, please ask an administrator to review your assigned role.</p>
    <a asp-page="/Index" class="btn btn-primary">Back to dashboard</a>
</section>
